<?xml version="1.0" encoding="UTF-8"?>
<!--
  scripts/windows/fractalsql.wxs — WiX Toolset source for the
  FractalSQL MySQL UDF Windows MSI.

  Driven by four preprocessor vars supplied by build-msi.bat:
    -dMYSQL_MAJOR=8.0 | 8.4 | 9.1          (dotted, for display)
    -dMYSQL_MAJOR_TAG=8_0 | 8_4 | 9_1      (sanitized, for WiX IDs)
    -dMYSQL_MAJOR_HEX=0800 | 0804 | 0901   (4 hex chars, for GUIDs)
    -dSTAGE_DIR=dist\windows\staging-my...
    -dMSI_VERSION=1.0.0
  plus the standard candle -arch x64, which populates
  $(sys.BUILDARCH) and selects the Package Platform attribute.

  UX flow
    1. Welcome / EULA (bundled LICENSE).
    2. WixUI_InstallDir lets the user pick the MySQL install root
       (default: C:\Program Files\MySQL\MySQL Server X.Y). This
       must be the folder that Oracle's own MSI server installer
       created, i.e. the folder containing lib\plugin\.
    3. Install copies fractalsql.dll into lib\plugin\, and the
       install SQL plus LICENSE files into
       share\doc\mysql-fractalsql\.
    4. Uninstall removes every file cleanly.

  Per-MySQL-major UpgradeCode
    Each MySQL major gets its own UpgradeCode so installing the
    8.0 and 8.4 MSIs side-by-side does not trigger MajorUpgrade on
    either. ProductId=* forces a fresh ProductCode per build, so
    re-installing the same MSI overwrites cleanly.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <?if $(var.MYSQL_MAJOR_HEX) = "0800" ?>
      <?define UpgradeCode = "C2F7B6E1-3B20-4D12-AEB4-DF02BB60EC01" ?>
  <?elseif $(var.MYSQL_MAJOR_HEX) = "0804" ?>
      <?define UpgradeCode = "C2F7B6E1-3B20-4D12-AEB4-DF02BB60EC02" ?>
  <?elseif $(var.MYSQL_MAJOR_HEX) = "0901" ?>
      <?define UpgradeCode = "C2F7B6E1-3B20-4D12-AEB4-DF02BB60EC03" ?>
  <?else ?>
      <?error Unsupported MYSQL_MAJOR_HEX: $(var.MYSQL_MAJOR_HEX) ?>
  <?endif ?>

  <Product Id="*"
           Name="FractalSQL for MySQL $(var.MYSQL_MAJOR)"
           Language="1033"
           Version="$(var.MSI_VERSION)"
           Manufacturer="FractalSQLabs"
           UpgradeCode="$(var.UpgradeCode)">

    <Package InstallerVersion="300"
             Compressed="yes"
             InstallScope="perMachine"
             Platform="$(sys.BUILDARCH)"
             Description="FractalSQL MySQL $(var.MYSQL_MAJOR) UDF installer"
             Manufacturer="FractalSQLabs" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of FractalSQL for MySQL $(var.MYSQL_MAJOR) is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- WixUI_InstallDir targets the MySQL-install-root folder. The
         power-user override for a non-default MySQL root (e.g.
         D:\MySQL\MySQL Server 8.4) retargets the whole tree —
         fractalsql.dll still lands under lib\plugin\ of that chosen
         root. PLUGINDIR is exposed separately for scripted installs
         that want to point the DLL at an even more unusual location. -->
    <Property Id="WIXUI_INSTALLDIR" Value="MYSQLROOT" />

    <!-- Registry-backed install-root auto-discovery.

         Oracle's MySQL Installer records the per-major server install
         directory under
           HKLM\SOFTWARE\MySQL AB\MySQL Server <MAJOR>\Location  (REG_SZ)
         so picking up that value lets this MSI land fractalsql.dll
         inside the real lib\plugin\ of whichever MySQL the admin
         actually chose — including non-default drive installs like
         D:\MySQL\MySQL Server 8.4\ — without the user having to
         retarget the folder picker.

         When the property Id matches a Directory Id, MSI substitutes
         the property value for the directory's computed default path
         during CostFinalize, and WixUI_InstallDir reads it as the
         folder-picker's initial value. If the key is absent (e.g.
         zip-based MySQL installs don't write it), the property stays
         empty and the default directory tree below takes over.

         Win64="yes" routes the search at the 64-bit registry view —
         correct since Platform="x64" is the only supported arch here
         and MySQL's 64-bit installer writes to the 64-bit hive. -->
    <Property Id="MYSQLROOT">
      <RegistrySearch Id="SearchMySQLServerLocation"
                      Root="HKLM"
                      Key="SOFTWARE\MySQL AB\MySQL Server $(var.MYSQL_MAJOR)"
                      Name="Location"
                      Type="raw"
                      Win64="yes" />
    </Property>

    <!-- Oracle does not publish 32-bit or ARM64 Windows server
         binaries on the current MySQL majors (8.0 / 8.4 / 9.x), so
         there's no host server for a win32 x86 or arm64 UDF DLL.
         Both cells are deferred until upstream host binaries exist. -->
    <?if $(sys.BUILDARCH) = "x86" ?>
        <?error MySQL UDFs are not shipped for win32 x86 (no MySQL host binary). ?>
    <?endif ?>
    <?if $(sys.BUILDARCH) = "arm64" ?>
        <?error MySQL UDFs are not shipped for Windows ARM64 (no MySQL host binary). ?>
    <?endif ?>

    <!--
         Directory layout mirrors the Oracle MySQL Windows default
         install:
           C:\Program Files\MySQL\MySQL Server X.Y\
             lib\
               plugin\            fractalsql.dll
             share\
               doc\
                 mysql-fractalsql\ LICENSE
                                   LICENSE-THIRD-PARTY
                                   install_udf.sql
                                   README.txt
    -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="MYSQLPARENT" Name="MySQL">
          <Directory Id="MYSQLROOT" Name="MySQL Server $(var.MYSQL_MAJOR)">
            <Directory Id="LibDir" Name="lib">
              <Directory Id="PLUGINDIR" Name="plugin" />
            </Directory>
            <Directory Id="ShareDir" Name="share">
              <Directory Id="DocDir" Name="doc">
                <Directory Id="FractalSqlDocDir" Name="mysql-fractalsql" />
              </Directory>
            </Directory>
          </Directory>
        </Directory>
      </Directory>
    </Directory>

    <!-- Each file is its own Component so uninstall removes exactly
         the set we installed — no orphan files, no touching existing
         MySQL files. GUIDs embed MYSQL_MAJOR_HEX so each
         (major, file) pair is deterministic across rebuilds without
         colliding across majors. -->

    <ComponentGroup Id="CoreFiles">

      <Component Id="c_FractalSqlDll"
                 Directory="PLUGINDIR"
                 Guid="F$(var.MYSQL_MAJOR_HEX)001-0000-4000-B000-00000000DA01">
        <File Id="fractalsql.dll"
              Source="$(var.STAGE_DIR)\fractalsql.dll"
              KeyPath="yes" />
      </Component>

      <Component Id="c_InstallUdfSql"
                 Directory="FractalSqlDocDir"
                 Guid="F$(var.MYSQL_MAJOR_HEX)002-0000-4000-B000-000000005510">
        <File Id="install_udf.sql"
              Source="$(var.STAGE_DIR)\install_udf.sql"
              KeyPath="yes" />
      </Component>

      <Component Id="c_License"
                 Directory="FractalSqlDocDir"
                 Guid="F$(var.MYSQL_MAJOR_HEX)003-0000-4000-B000-0000000011CE">
        <File Id="LICENSE.txt"
              Name="LICENSE"
              Source="$(var.STAGE_DIR)\LICENSE"
              KeyPath="yes" />
      </Component>

      <Component Id="c_LicenseThirdParty"
                 Directory="FractalSqlDocDir"
                 Guid="F$(var.MYSQL_MAJOR_HEX)004-0000-4000-B000-00000003DA7A">
        <File Id="LICENSE_THIRD_PARTY.txt"
              Name="LICENSE-THIRD-PARTY"
              Source="$(var.STAGE_DIR)\LICENSE-THIRD-PARTY"
              KeyPath="yes" />
      </Component>

      <Component Id="c_Readme"
                 Directory="FractalSqlDocDir"
                 Guid="F$(var.MYSQL_MAJOR_HEX)005-0000-4000-B000-00000000AD11">
        <File Id="README.txt"
              Source="$(var.STAGE_DIR)\README.txt"
              KeyPath="yes" />
      </Component>

    </ComponentGroup>

    <Feature Id="MainFeature"
             Title="FractalSQL for MySQL $(var.MYSQL_MAJOR)"
             Level="1"
             Display="expand"
             AllowAdvertise="no">
      <ComponentGroupRef Id="CoreFiles" />
    </Feature>

    <!-- Standard WixUI_InstallDir flow (Welcome -> EULA -> FolderDlg ->
         Ready -> Progress). Folder picker lets power-users retarget a
         non-default MySQL install root. -->
    <UIRef Id="WixUI_InstallDir" />
    <UIRef Id="WixUI_ErrorProgressText" />

  </Product>
</Wix>
